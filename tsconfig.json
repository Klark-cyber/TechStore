{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true, // Kutubxonalar ichidagi mantiqsiz xatolarni e'tiborsiz qoldiradi
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,      // VAQTINCHA: Xatolarni kamaytirish uchun false qilib turing
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",      // "react-jsx"dan "react"ga o'zgartiring (v17 uchun mosroq)
    "paths": {           // Turlarni majburan bitta joyga yo'naltirish
      "react": ["./node_modules/@types/react"]
    }
  },
  "include": [
    "src"
  ]
}